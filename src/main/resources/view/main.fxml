<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1040.0"
            styleClass="app-shell"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ciber.MainController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
            <padding>
                <Insets bottom="12" left="16" right="16" top="12"/>
            </padding>
            <Label styleClass="brand-mark" text="CL"/>
            <VBox spacing="1">
                <Label styleClass="app-title" text="CiberLightCol"/>
                <Label styleClass="muted-text" text="Sistema de producción"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label styleClass="muted-text" text="Operador"/>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="176.0" spacing="8.0" styleClass="sidebar">
            <padding>
                <Insets bottom="16" left="12" right="12" top="16"/>
            </padding>
            <Button maxWidth="Infinity" onAction="#openDashboard" styleClass="nav-button" text="Dashboard"/>
            <Button maxWidth="Infinity" onAction="#openLotes" styleClass="nav-button" text="Lotes"/>
            <Button maxWidth="Infinity" onAction="#openTecnicos" styleClass="nav-button" text="Tecnicos"/>
            <Button maxWidth="Infinity" onAction="#openMateriales" styleClass="nav-button" text="Materiales"/>
            <Button maxWidth="Infinity" onAction="#openAlertas" styleClass="nav-button" text="Alertas"/>
        </VBox>
    </left>

    <center>
        <AnchorPane fx:id="contentArea" styleClass="content-area"/>
    </center>

</BorderPane>
