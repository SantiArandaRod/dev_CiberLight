<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="720.0" prefHeight="400.0"
            fx:controller="com.ciber.MainController"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">

    <!-- BARRA SUPERIOR -->
    <top>
        <HBox spacing="10.0" style="-fx-background-color:#d9d9d9;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <children>

                <Pane prefWidth="80.0" prefHeight="40.0" style="-fx-border-color:black;">
                    <children>
                        <Label text="LOGO" layoutX="15" layoutY="12"/>
                    </children>
                </Pane>

                <Label text="Sistema Gestión de Producción"
                       style="-fx-font-size:16px; -fx-font-weight:bold;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label text="Usuario:"/>
                <Label text="Operador"/>

            </children>
        </HBox>
    </top>

    <!-- MENU LATERAL -->
    <left>
        <VBox spacing="10.0" style="-fx-background-color:#e6e6e6;">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <children>

                <Button text="Dashboard" prefWidth="140" prefHeight="140" onAction="#openDashboard"/>
                <Button text="Lotes" prefWidth="140" prefHeight="140" onAction="#openLotes"/>
                <Button text="Técnicos" prefWidth="140" prefHeight="140" onAction="#openTecnicos"/>
                <Button text="Materiales" prefWidth="140" prefHeight="140" onAction="#openMateriales"/>
                <Button text="Alertas" prefWidth="140" prefHeight="140" onAction="#openAlertas"/>

            </children>
        </VBox>
    </left>

    <!-- AREA CENTRAL -->
    <center>
        <AnchorPane fx:id="contentArea"/>
    </center>

</BorderPane>

