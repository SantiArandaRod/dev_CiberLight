<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12"
      prefWidth="360"
      styleClass="page"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ciber.controller.AgregarTecnicoController">
    <padding>
        <Insets bottom="18" left="18" right="18" top="18"/>
    </padding>

    <Label styleClass="page-title" text="Agregar técnico"/>
    <TextField fx:id="txtNombre" promptText="Nombre"/>
    <TextField fx:id="txtEspecialidad" promptText="Especialidad"/>
    <Button maxWidth="Infinity" onAction="#guardarTecnico" styleClass="button-primary" text="Guardar"/>
</VBox>
