<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400" prefWidth="650"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ciber.controller.TecnicosController">

    <children>

        <VBox spacing="10"
              AnchorPane.topAnchor="10"
              AnchorPane.leftAnchor="10"
              AnchorPane.rightAnchor="10"
              AnchorPane.bottomAnchor="10">

            <Label text="Gestión de Técnicos"
                   style="-fx-font-size:18px; -fx-font-weight:bold;" />

            <TableView fx:id="tablaTecnicos" prefHeight="300">

                <columns>

                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="180"/>
                    <TableColumn fx:id="colEspecialidad" text="Especialidad" prefWidth="180"/>
                    <TableColumn fx:id="colLotes" text="Lotes Activos" prefWidth="100"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>

                </columns>

            </TableView>

            <HBox spacing="10">

                <Button text="Agregar Técnico"
                        onAction="#abrirAgregarTecnico"/>

                <Button text="Inactivar Técnico"
                        onAction="#inactivarTecnico"/>

            </HBox>

        </VBox>

    </children>

</AnchorPane>