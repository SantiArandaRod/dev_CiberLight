<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane styleClass="page"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ciber.controller.LoteController">

    <VBox spacing="14" AnchorPane.bottomAnchor="18" AnchorPane.leftAnchor="18"
          AnchorPane.rightAnchor="18" AnchorPane.topAnchor="18">
        <Label styleClass="page-title" text="Gestión de lotes"/>
        <Label styleClass="page-subtitle" text="Seguimiento de producción por técnico y cliente"/>

        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="toolbar">
            <ComboBox fx:id="comboTecnicos" prefWidth="240" promptText="Seleccionar técnico"/>
            <Button onAction="#crearLote" styleClass="button-primary" text="Crear"/>
            <Button onAction="#finalizarLote" styleClass="button-secondary" text="Finalizar"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#eliminarLote" styleClass="button-danger" text="Eliminar"/>
        </HBox>

        <TableView fx:id="tablaLotes" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNombre" prefWidth="190" text="Nombre"/>
                <TableColumn fx:id="colCliente" prefWidth="190" text="Cliente"/>
                <TableColumn fx:id="colTecnico" prefWidth="180" text="Técnico"/>
                <TableColumn fx:id="colEstado" prefWidth="130" text="Estado"/>
            </columns>
        </TableView>
    </VBox>

</AnchorPane>
