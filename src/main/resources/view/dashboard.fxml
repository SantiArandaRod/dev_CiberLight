<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">

    <VBox spacing="10.0" AnchorPane.topAnchor="10.0"
          AnchorPane.leftAnchor="10.0"
          AnchorPane.rightAnchor="10.0">

        <padding>
            <Insets top="10" right="10" bottom="10" left="10"/>
        </padding>

        <Label text="Dashboard Producción"
               style="-fx-font-size:16px; -fx-font-weight:bold;"/>

        <HBox spacing="10.0">

            <VBox style="-fx-border-color:gray; -fx-padding:10;">
                <Label text="Lotes Activos"/>
                <Label text="12"/>
            </VBox>

            <VBox style="-fx-border-color:gray; -fx-padding:10;">
                <Label text="Producción Hoy"/>
                <Label text="8"/>
            </VBox>

            <VBox style="-fx-border-color:gray; -fx-padding:10;">
                <Label text="Eficiencia"/>
                <Label text="87%"/>
            </VBox>

        </HBox>

        <BarChart prefHeight="180.0">
            <xAxis>
                <CategoryAxis label="Técnicos"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="Producción"/>
            </yAxis>
        </BarChart>

    </VBox>

</AnchorPane>