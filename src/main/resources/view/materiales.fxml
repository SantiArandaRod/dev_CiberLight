<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="423.0" prefWidth="567.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ciber.controller.MaterialesController">

    <VBox layoutY="4.0" prefHeight="386.0" prefWidth="482.0" spacing="10" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="8.0" AnchorPane.topAnchor="10.0">

        <padding>
            <Insets bottom="10" left="10" right="10" top="10" />
        </padding>

        <!-- TITULO -->

        <Label style="-fx-font-size:16px; -fx-font-weight:bold;" text="Inventario de Materiales" />

        <!-- BOTONES -->

        <HBox spacing="10">

            <Button onAction="#agregarMaterial" prefHeight="35" prefWidth="140" text="Añadir Material" />

            <Button onAction="#agregarStock" prefHeight="35" prefWidth="120" text="Entrada Stock" />

            <Button onAction="#eliminarStock" prefHeight="35" prefWidth="120" text="Salida Stock" />

            <Button onAction="#eliminarMaterial" prefHeight="35" prefWidth="140" text="Eliminar Material" />

        </HBox>

        <!-- TABLA -->

        <TableView fx:id="tablaMateriales" VBox.vgrow="ALWAYS">

            <columns>

                <TableColumn fx:id="colId" prefWidth="60" text="ID" />

                <TableColumn fx:id="colNombre" prefWidth="200" text="Material" />

                <TableColumn fx:id="colStock" prefWidth="100" text="Stock" />

                <TableColumn fx:id="colStockMinimo" prefWidth="120" text="Stock mínimo" />

            </columns>

        </TableView>

    </VBox>

</AnchorPane>
